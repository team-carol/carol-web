# 패치노트를 노션에서 불러오려면 아래 두 값을 설정하세요.
# (서버 전용 — NEXT_PUBLIC_ 접두사를 붙이지 마세요. 클라이언트에 노출되면 안 됩니다.)
# 값이 없거나 조회에 실패하면 lib/dictionary.ts의 fallbackTweets가 사용됩니다.
#
# 노션 DB에는 "링크"(URL) 속성 하나만 있으면 됩니다. 트윗 링크를 붙여넣으면
# 본문·이미지·날짜는 트윗에서 자동으로 가져옵니다. (X syndication 비공식 API)

# 노션 내부 통합(integration) 시크릿. https://www.notion.so/my-integrations 에서 발급.
NOTION_TOKEN=

# 패치노트 데이터베이스 ID. 통합을 해당 DB에 "연결(Connections)"한 뒤,
# DB URL의 32자리 해시가 ID입니다. 예: notion.so/workspace/<여기가_ID>?v=...
NOTION_PATCHNOTES_DB=

# --- 선택: 기본값 오버라이드 --------------------------------------------------
# NEXT_PUBLIC_INVITE_URL=
# NEXT_PUBLIC_USER_COUNT=
# NEXT_PUBLIC_SERVER_COUNT=
# NEXT_PUBLIC_VERSION=
